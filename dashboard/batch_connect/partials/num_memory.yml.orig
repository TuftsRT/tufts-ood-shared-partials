num_memory:
  widget: "select"
  label: "Amount of memory"
  help: |
    Amount of memory (in GB).
  options:
    - ["1GB", "1000"]
    - ["2GB", "2000"]
    - ["4GB", "4000"]
    - ["8GB", "8000"]
    - ["16GB", "16000"]
    - ["32GB", "32000"]
    - ["64GB", "64000"]
    - ["128GB", "128000"]
    - ["250GB", "250000"]
  id: 'num_memory'
